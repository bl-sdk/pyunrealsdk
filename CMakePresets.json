{
  "version": 3,
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "EXPLICIT_PYTHON_VERSION": "3.14.3"
      }
    },
    {
      "name": "_clang_x86",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "$env{VSINSTALLDIR}",
        "rhs": ""
      },
      "generator": "Ninja",
      "toolchainFile": "common_cmake/clang-x86.cmake"
    },
    {
      "name": "_clang_x64",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "$env{VSINSTALLDIR}",
        "rhs": ""
      },
      "generator": "Ninja",
      "toolchainFile": "common_cmake/clang-x64.cmake"
    },
    {
      "name": "_clang_cross_x86",
      "hidden": true,
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "MSVC_WINE_ENV_SCRIPT": "/win-sdk/bin/x86/msvcenv.sh"
      },
      "generator": "Ninja",
      "toolchainFile": "common_cmake/clang-cross-x86.cmake"
    },
    {
      "name": "_clang_cross_x64",
